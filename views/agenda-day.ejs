<%- include('partials/head') %>
<main class="agenda-shell">
  <header class="agenda-top">
    <div><img src="<%= s.logo_url || '/public/assets/logo.svg' %>" alt="Biruta"><h1>Agenda Biruta Park</h1><p><%= date.split('-').reverse().join('/') %></p></div>
    <nav><a href="/agendadecoracao?year=<%= Number(date.slice(0,4)) %>&month=<%= Number(date.slice(5,7)) %>">Voltar ao calendário</a><a href="/agendadecoracao/relatorio">Relatório</a><a href="/agendadecoracao/logout">Sair</a></nav>
  </header>
  <section class="agenda-day-layout">
    <div class="card"><h2>Festas cadastradas</h2><% if(!events.length){ %><p class="muted">Nenhuma festa cadastrada para esta data.</p><% } %><% events.forEach(ev=>{ const pend=String(ev.theme||'').trim().toUpperCase()==='Á DECIDIR'; %><div class="event-mini <%= pend?'event-pending':'event-ok' %>"><b><%= ev.birthday_name || 'Aniversariante' %></b><span><strong>Responsável:</strong> <%= ev.responsible_name || '-' %></span><span><strong>WhatsApp:</strong> <%= ev.whatsapp || '-' %></span><span><strong>Idade:</strong> <%= ev.birthday_age || '-' %></span><span><strong>Arco:</strong> <%= ev.has_arch || '-' %></span><span><strong>Tema:</strong> <%= ev.theme || '-' %></span><% if(ev.notes){ %><span><strong>Observações:</strong> <%= ev.notes %></span><% } %><div><% if(canEditAgenda()){ %><a class="btn tiny" href="/agendadecoracao/editar/<%= ev.id %>">Editar</a><% } %><a class="btn tiny whatsapp" href="<%= whatsUrl(ev.whatsapp, 'Olá! Tudo bem? Gostaria de falar sobre a decoração da festa.') %>" target="_blank">WhatsApp</a></div></div><% }) %></div>
    <% if(canEditAgenda()){ %>
    <div class="card"><h2><%= edit ? 'Editar festa' : 'Adicionar festa' %></h2><form class="form-grid agenda-form" method="post" action="/agendadecoracao/salvar"><input type="hidden" name="id" value="<%= edit ? edit.id : '' %>"><input type="hidden" name="date" value="<%= date %>"><label>Nome do responsável<input name="responsible_name" placeholder="Nome do responsável" value="<%= edit ? edit.responsible_name : '' %>" required></label><label>WhatsApp do responsável<input name="whatsapp" placeholder="(16) 99999-9999" value="<%= edit ? edit.whatsapp : '' %>"></label><label>Nome do aniversariante<input name="birthday_name" placeholder="Nome do aniversariante" value="<%= edit ? edit.birthday_name : '' %>"></label><label>Idade que irá fazer<input name="birthday_age" placeholder="Ex: 5" value="<%= edit ? edit.birthday_age : '' %>"></label><label>Arco<select name="has_arch"><option value="Sim" <%= edit && edit.has_arch==='Sim'?'selected':'' %>>Sim</option><option value="Não" <%= !edit || edit.has_arch==='Não'?'selected':'' %>>Não</option></select></label><label>Tema<select name="theme" id="themeSelect"><% themes.forEach(t=>{ %><option value="<%= t %>" <%= edit && edit.theme===t?'selected':'' %>><%= t %></option><% }) %><option value="PERSONALIZADO">PERSONALIZADO</option></select></label><input id="customTheme" name="custom_theme" placeholder="Digite o novo tema personalizado" style="display:none"><label class="wide">Observações<textarea name="notes" placeholder="Observações sobre decoração, arco, detalhes e combinados"><%= edit ? edit.notes : '' %></textarea></label><button class="btn"><%= edit ? 'Salvar alterações' : 'Salvar festa' %></button></form><% if(edit){ %><form method="post" action="/agendadecoracao/excluir/<%= edit.id %>" onsubmit="return confirm('Excluir esta festa?')"><button class="danger">Excluir festa</button></form><% } %></div>
    <% } else { %><div class="card"><h2>Modo visualização</h2><p class="muted">Seu usuário pode apenas consultar a agenda.</p></div><% } %>
  </section>
</main><script>const sel=document.getElementById('themeSelect'), custom=document.getElementById('customTheme'); function toggle(){if(!sel||!custom)return; custom.style.display=sel.value==='PERSONALIZADO'?'block':'none'; if(sel.value==='PERSONALIZADO') custom.focus();} sel&&sel.addEventListener('change',toggle); toggle(); document.querySelectorAll('.agenda-form input,.agenda-form select,.agenda-form textarea').forEach((el,i,arr)=>{el.addEventListener('keydown',e=>{if(e.key==='Enter'&&el.tagName!=='TEXTAREA'){e.preventDefault(); const n=arr[i+1]; if(n) n.focus(); else el.form.requestSubmit();}})});</script></body></html>
