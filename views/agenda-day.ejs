<%- include('partials/head') %>
<main class="agenda-shell">
  <header class="agenda-top"><div><img src="<%= s.logo_url || '/public/assets/logo.svg' %>" alt="Biruta"><h1>Agenda do dia</h1><p><%= date.split('-').reverse().join('/') %></p></div><nav><a href="/agendamonise?year=<%= Number(date.slice(0,4)) %>&month=<%= Number(date.slice(5,7)) %>">Voltar ao calendário</a><a href="/admin/logout">Sair</a></nav></header>
  <section class="agenda-day-layout">
    <div class="card"><h2>Festas cadastradas</h2><% if(!events.length){ %><p class="muted">Nenhuma festa cadastrada para esta data.</p><% } %><% events.forEach(ev=>{ %><div class="event-mini"><b><%= ev.birthday_name || 'Aniversariante' %></b><span><%= ev.responsible_name %> • <%= ev.theme %></span><span>Arco: <%= ev.has_arch %> | Idade: <%= ev.birthday_age %></span><div><a class="btn tiny" href="/agendamonise/editar/<%= ev.id %>">Editar</a><a class="btn tiny whatsapp" href="<%= whatsUrl(ev.whatsapp, 'Olá! Tudo bem? Gostaria de falar sobre a decoração da festa.') %>" target="_blank">WhatsApp</a></div></div><% }) %></div>
    <div class="card"><h2><%= edit ? 'Editar festa' : 'Adicionar festa' %></h2><form class="form-grid agenda-form" method="post" action="/agendamonise/salvar"><input type="hidden" name="id" value="<%= edit ? edit.id : '' %>"><input type="hidden" name="date" value="<%= date %>"><input name="responsible_name" placeholder="Nome do responsável" value="<%= edit ? edit.responsible_name : '' %>" required><input name="whatsapp" placeholder="WhatsApp do responsável" value="<%= edit ? edit.whatsapp : '' %>"><input name="birthday_name" placeholder="Nome do aniversariante" value="<%= edit ? edit.birthday_name : '' %>"><input name="birthday_age" placeholder="Idade que irá fazer" value="<%= edit ? edit.birthday_age : '' %>"><select name="has_arch"><option <%= edit && edit.has_arch==='Sim'?'selected':'' %>>Sim</option><option <%= !edit || edit.has_arch==='Não'?'selected':'' %>>Não</option></select><select name="theme" id="themeSelect"><% themes.forEach(t=>{ %><option value="<%= t %>" <%= edit && edit.theme===t?'selected':'' %>><%= t %></option><% }) %><option value="PERSONALIZADO">PERSONALIZADO</option></select><input id="customTheme" name="custom_theme" placeholder="Digite o novo tema personalizado" style="display:none"><textarea name="notes" placeholder="Observações"><%= edit ? edit.notes : '' %></textarea><button class="btn"><%= edit ? 'Salvar alterações' : 'Salvar festa' %></button></form><% if(edit){ %><form method="post" action="/agendamonise/excluir/<%= edit.id %>" onsubmit="return confirm('Excluir esta festa?')"><button class="danger">Excluir festa</button></form><% } %></div>
  </section>
</main><script>const sel=document.getElementById('themeSelect'), custom=document.getElementById('customTheme'); function toggle(){custom.style.display=sel.value==='PERSONALIZADO'?'block':'none'; if(sel.value==='PERSONALIZADO') custom.focus();} sel&&sel.addEventListener('change',toggle); toggle(); document.querySelectorAll('.agenda-form input,.agenda-form select,.agenda-form textarea').forEach((el,i,arr)=>{el.addEventListener('keydown',e=>{if(e.key==='Enter'&&el.tagName!=='TEXTAREA'){e.preventDefault(); const n=arr[i+1]; if(n) n.focus(); else el.form.requestSubmit();}})});</script></body></html>
