<%- include('partials/head') %>
<main class="agenda-shell calendar-only-shell">
  <header class="calendar-only-top">
    <a class="btn ghost" href="/agendadecoracao">← Início</a>
    <div>
      <h1>Calendário de Decorações</h1>
      <p>Selecione uma data para visualizar ou cadastrar festas.</p>
    </div>
    <a class="btn" href="/agendadecoracao/relatorio">Relatório</a>
  </header>

  <% if(saved){ %><div class="toast-ok">Alterações salvas com sucesso!</div><% } %>
  <% if(restored){ %><div class="toast-ok">Festa restaurada com sucesso!</div><% } %>

  <% const monthNames=['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro']; const first=new Date(year,month-1,1); const last=new Date(year,month,0); const startDay=first.getDay(); const prevMonth=month===1?12:month-1; const prevYear=month===1?year-1:year; const nextMonth=month===12?1:month+1; const nextYear=month===12?year+1:year; const byDate={}; events.forEach(e=>{(byDate[e.date] ||= []).push(e)}); %>
  <section class="calendar-card calendar-only-card">
    <div class="calendar-head">
      <a class="cal-arrow" href="/agendadecoracao/calendario?year=<%= prevYear %>&month=<%= prevMonth %>">‹</a>
      <h2><%= monthNames[month-1] %> de <%= year %></h2>
      <a class="cal-arrow" href="/agendadecoracao/calendario?year=<%= nextYear %>&month=<%= nextMonth %>">›</a>
    </div>
    <div class="agenda-legend"><span><i class="dot green"></i>Tema definido</span><span><i class="dot red"></i>Á DECIDIR</span></div>
    <div class="calendar-scroll">
      <div class="weekdays"><span>Dom</span><span>Seg</span><span>Ter</span><span>Qua</span><span>Qui</span><span>Sex</span><span>Sáb</span></div>
      <div class="calendar-grid">
        <% for(let i=0;i<startDay;i++){ %><div class="day blank"></div><% } %>
        <% for(let d=1; d<=last.getDate(); d++){ const dateStr=`${year}-${String(month).padStart(2,'0')}-${String(d).padStart(2,'0')}`; const list=byDate[dateStr]||[]; const today=new Date().toISOString().slice(0,10)===dateStr; const hasPending=list.some(ev=>String(ev.theme||'').trim().toUpperCase()==='Á DECIDIR'); %>
          <a class="day <%= today?'today':'' %> <%= list.length ? (hasPending?'pending-day':'ok-day') : '' %>" href="/agendadecoracao/dia/<%= dateStr %>">
            <strong><%= d %></strong>
            <% if(list.length){ %>
              <em><%= list.length %> festa<%= list.length>1?'s':'' %></em>
              <% list.slice(0,3).forEach(ev=>{ const pend=String(ev.theme||'').trim().toUpperCase()==='Á DECIDIR'; %>
                <small class="<%= pend?'pending-mini':'ok-mini' %>"><%= ev.birthday_name || ev.responsible_name %> • <%= ev.theme %></small>
              <% }) %>
            <% } else { %>
              <small class="empty-day"><%= canEditAgenda() ? 'Adicionar festa' : 'Sem festas' %></small>
            <% } %>
          </a>
        <% } %>
      </div>
    </div>
  </section>
</main></body></html>
