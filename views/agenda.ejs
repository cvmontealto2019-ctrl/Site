<%- include('partials/head') %>
<main class="agenda-shell">
  <header class="agenda-top">
    <div><img src="<%= s.logo_url || '/public/assets/logo.svg' %>" alt="Biruta"><h1>Agenda Biruta Park</h1><p>Calendário interno de decoração</p></div>
    <nav>
      <a href="/agendadecoracao">Calendário</a>
      <a href="/agendadecoracao/relatorio">Relatório</a>
      <% if(agenda_user && agenda_user.role==='admin'){ %><a href="/agendadecoracao/usuarios">Usuários</a><a href="/agendadecoracao/lixeira">Restaurar festas</a><% } %>
      <a href="/agendadecoracao/logout">Sair</a>
    </nav>
  </header>
  <% if(saved){ %><div class="toast-ok">Alterações salvas com sucesso!</div><% } %><% if(restored){ %><div class="toast-ok">Festa restaurada com sucesso!</div><% } %>
  <section class="agenda-status-grid">
    <div class="status-card <%= stats.pending.length ? 'danger-status' : 'success-status' %>">
      <span>Status das próximas 30 festas</span>
      <% if(stats.pending.length){ %>
        <strong><%= stats.pending.length %> festa<%= stats.pending.length>1?'s':'' %> com tema Á DECIDIR</strong>
        <p>Essas festas aparecem em vermelho para lembrar que precisam de contato com a cliente.</p>
      <% } else { %>
        <strong>Nenhuma pendência nos próximos 30 cadastros</strong>
        <p>Todas as próximas festas já estão com tema definido.</p>
      <% } %>
    </div>
    <div class="status-card neutral-status">
      <span>Total visualizado</span>
      <strong><%= stats.next30.length %> festa<%= stats.next30.length!==1?'s':'' %></strong>
      <p>Contagem baseada nas próximas 30 festas cadastradas a partir de hoje.</p>
    </div>
  </section>
  <% const monthNames=['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro']; const first=new Date(year,month-1,1); const last=new Date(year,month,0); const startDay=first.getDay(); const prevMonth=month===1?12:month-1; const prevYear=month===1?year-1:year; const nextMonth=month===12?1:month+1; const nextYear=month===12?year+1:year; const byDate={}; events.forEach(e=>{(byDate[e.date] ||= []).push(e)}); %>
  <section class="calendar-card">
    <div class="calendar-head"><a class="cal-arrow" href="/agendadecoracao?year=<%= prevYear %>&month=<%= prevMonth %>">‹</a><h2><%= monthNames[month-1] %> de <%= year %></h2><a class="cal-arrow" href="/agendadecoracao?year=<%= nextYear %>&month=<%= nextMonth %>">›</a></div>
    <div class="agenda-legend"><span><i class="dot green"></i>Tema definido</span><span><i class="dot red"></i>Á DECIDIR</span></div>
    <div class="weekdays"><span>Dom</span><span>Seg</span><span>Ter</span><span>Qua</span><span>Qui</span><span>Sex</span><span>Sáb</span></div>
    <div class="calendar-grid">
      <% for(let i=0;i<startDay;i++){ %><div class="day blank"></div><% } %>
      <% for(let d=1; d<=last.getDate(); d++){ const dateStr=`${year}-${String(month).padStart(2,'0')}-${String(d).padStart(2,'0')}`; const list=byDate[dateStr]||[]; const today=new Date().toISOString().slice(0,10)===dateStr; const hasPending=list.some(ev=>String(ev.theme||'').trim().toUpperCase()==='Á DECIDIR'); %>
        <a class="day <%= today?'today':'' %> <%= list.length ? (hasPending?'pending-day':'ok-day') : '' %>" href="/agendadecoracao/dia/<%= dateStr %>"><strong><%= d %></strong><% if(list.length){ %><em><%= list.length %> festa<%= list.length>1?'s':'' %></em><% list.slice(0,2).forEach(ev=>{ const pend=String(ev.theme||'').trim().toUpperCase()==='Á DECIDIR'; %><small class="<%= pend?'pending-mini':'ok-mini' %>"><%= ev.birthday_name || ev.responsible_name %> • <%= ev.theme %></small><% }) %><% } else { %><small class="empty-day"><%= canEditAgenda() ? 'Adicionar festa' : 'Sem festas' %></small><% } %></a>
      <% } %>
    </div>
  </section>
</main></body></html>
