<%- include('partials/head') %><%- include('partials/header') %><main class="section"><h1>Promoções</h1><div class="cards"><% promos.forEach(p=>{ %><article class="card"><% if(p.image_url){ %><img class="thumb" src="<%= p.image_url %>"><% } %><span><%= p.active?'Ativa':'Encerrada' %></span><h3><%= p.title %></h3><p><%= p.description %></p><a class="btn small" href="<%= p.link %>"><%= p.button_text %></a></article><% }) %></div></main><%- include('partials/footer') %>
