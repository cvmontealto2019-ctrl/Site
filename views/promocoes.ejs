<%- include('partials/head') %><%- include('partials/header') %><main class="section"><div class="section-head"><span class="pill">Promoções</span><h1>Campanhas do Biruta Park</h1></div><div class="cards"><% promos.forEach(p=>{ %><article class="card"><% if(p.image_url){ %><img class="thumb" src="<%= p.image_url %>"><% } %><h3><%= p.title %></h3><p><%= p.description %></p><p><b><%= p.active?'Ativa':'Encerrada' %></b></p><% if(p.link){ %><a class="btn small" href="<%= promoLink(p.link) %>"><%= p.button_text||'Acessar' %></a><% } %></article><% }) %></div></main><%- include('partials/footer') %>
