<%- include('partials/head') %><div class="admin-wrap"><aside><h2>Biruta Admin</h2><a href="/admin">Dashboard</a><a href="/admin/orcamentos">Orçamentos</a><a href="/admin/site">Site e promoções</a><a href="/admin/leads">Leads</a><a href="/admin/logout">Sair</a></aside><main class="admin-main">
<% if(page==='dashboard'){ %><h1>Dashboard</h1><div class="cards"><div class="card"><h3>Últimos orçamentos</h3><% leads.forEach(l=>{ %><p><b><%= l.name %></b> — <%= l.package_name %> — <%= money(l.total) %></p><% }) %></div></div><% } %>
<% if(page==='orcamentos'){ %><h1>Orçamentos por ano</h1><form class="inline" method="post" action="/admin/year"><input name="year" placeholder="2028"><label><input type="checkbox" name="active" checked> ativo</label><button class="btn small">Adicionar ano</button></form><div class="cards"><% yrs.forEach(y=>{ %><div class="card"><h3><%= y.year %></h3><p><%= y.active?'Ativo':'Inativo' %></p><form method="post" action="/admin/year/<%= y.id %>/toggle"><button class="btn small">Ativar/desativar</button></form></div><% }) %></div><h2>Adicionar/editar pacote</h2><form class="form-grid" method="post" action="/admin/package"><select name="year_id"><% yrs.forEach(y=>{ %><option value="<%= y.id %>"><%= y.year %></option><% }) %></select><input name="name" placeholder="Nome do pacote"><input name="subtitle" placeholder="Ex: 50 pessoas"><input name="base_people" type="number" placeholder="Pessoas base"><input name="base_price" type="number" step="0.01" placeholder="Valor base"><input name="card_price" type="number" step="0.01" placeholder="Valor cartão (opcional)"><input name="additional_price" type="number" step="0.01" placeholder="Valor adicional"><input name="duration" placeholder="Duração"><input name="availability" placeholder="Dias disponíveis"><textarea name="included" placeholder="Inclusos"></textarea><textarea name="rules" placeholder="Regras"></textarea><label><input type="checkbox" name="active" checked> Ativo</label><label><input type="checkbox" name="featured"> Destaque</label><button class="btn">Salvar pacote</button></form><h2>Pacotes cadastrados</h2><div class="table"><table><tr><th>Ano</th><th>Pacote</th><th>Base</th><th>Adicional</th><th>Status</th><th></th></tr><% packs.forEach(p=>{ %><tr><td><%= p.year %></td><td><%= p.name %></td><td><%= money(p.base_price) %></td><td><%= money(p.additional_price) %></td><td><%= p.active?'Ativo':'Inativo' %></td><td><form method="post" action="/admin/package/<%= p.id %>/delete"><button>Excluir</button></form></td></tr><% }) %></table></div><% } %>
<% if(page==='site'){ %><h1>Site, banners e promoções</h1><h2>Informações gerais</h2><form class="form-grid" method="post" action="/admin/settings"><input name="site_title" value="<%= s.site_title %>"><input name="whatsapp" value="<%= s.whatsapp %>"><input name="instagram" value="<%= s.instagram %>"><input name="address" value="<%= s.address %>"><input name="hero_title" value="<%= s.hero_title %>"><textarea name="hero_subtitle"><%= s.hero_subtitle %></textarea><input name="footer_text" value="<%= s.footer_text %>"><button class="btn">Salvar</button></form><h2>Novo banner</h2><form class="form-grid" method="post" enctype="multipart/form-data" action="/admin/banner"><input name="title" placeholder="Título"><input name="subtitle" placeholder="Subtítulo"><input name="button_text" placeholder="Texto do botão"><input name="button_link" placeholder="Link"><input type="file" name="image"><input name="sort_order" placeholder="Ordem"><label><input type="checkbox" name="active" checked> Ativo</label><button class="btn">Adicionar banner</button></form><h2>Nova promoção</h2><form class="form-grid" method="post" enctype="multipart/form-data" action="/admin/promotion"><input name="title" placeholder="Título"><textarea name="description" placeholder="Descrição"></textarea><input name="button_text" placeholder="Texto do botão"><input name="link" placeholder="Link da promoção"><input type="file" name="image"><input type="date" name="starts_at"><input type="date" name="ends_at"><label><input type="checkbox" name="active" checked> Ativa</label><label><input type="checkbox" name="highlight" checked> Destaque na home</label><button class="btn">Adicionar promoção</button></form><% } %>
<% if(page==='leads'){ %><h1>Leads / Orçamentos</h1><div class="table"><table><tr><th>Cliente</th><th>WhatsApp</th><th>Festa</th><th>Pacote</th><th>Total</th><th>Status</th></tr><% leads.forEach(l=>{ %><tr><td><%= l.name %></td><td><a href="https://wa.me/55<%= String(l.whatsapp).replace(/\D/g,'') %>"><%= l.whatsapp %></a></td><td><%= l.birthday_name %> • <%= l.guests %> convidados</td><td><%= l.package_name %> <%= l.year %></td><td><%= money(l.total) %></td><td><form method="post" action="/admin/leads/<%= l.id %>/status"><select name="status"><option><%= l.status %></option><option>novo</option><option>em atendimento</option><option>fechado</option><option>perdido</option></select><input name="notes" value="<%= l.notes||'' %>" placeholder="Observações"><button>Salvar</button></form></td></tr><% }) %></table></div><% } %>
</main></div></body></html>
