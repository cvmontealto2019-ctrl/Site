<%- include('partials/head') %>
<div class="admin-wrap"><aside><h2>Biruta Admin</h2><a href="/admin">Dashboard</a><a href="/admin/orcamentos">Orçamentos</a><a href="/admin/site">Site e promoções</a><a href="/admin/leads">Leads</a><a href="/admin/senha">Trocar login/senha</a><a href="/admin/logout">Sair</a></aside><main class="admin-main">
<% if(page==='dashboard'){ %>
  <h1>Dashboard</h1><div class="cards"><div class="card"><h3>Últimas solicitações</h3><% leads.forEach(l=>{ %><p><b><%= l.name %></b> — <%= l.package_name %> — <%= l.guests %> convidados</p><% }) %></div></div>
<% } %>

<% if(page==='senha'){ %>
  <h1>Trocar login e senha do painel</h1><div class="card"><% if(error){ %><p class="error"><%= error %></p><% } %><% if(ok){ %><p class="ok"><%= ok %></p><% } %><form class="form-grid" method="post" action="/admin/senha"><input name="new_login" placeholder="Novo login" value="<%= (current_user && current_user.login) || '17717592000160' %>"><input name="current_password" type="password" placeholder="Senha atual"><input name="new_password" type="password" placeholder="Nova senha"><input name="confirm_password" type="password" placeholder="Confirmar nova senha"><button class="btn">Salvar login e senha</button></form></div>
<% } %>

<% if(page==='orcamentos'){ %>
  <% const catNames=['ENTRADAS','SALGADOS FRITOS','SALGADOS ASSADOS','LANCHE','FINGER FOOD','PEGA PIZZA','GOURMET','BOLO','DOCINHOS','PICOLÉ','BEBIDAS','E MAIS','HORA DO PARABÉNS','REGRAS']; %>
  <h1>Orçamentos por ano</h1>
  <form class="inline" method="post" action="/admin/year"><input name="year" placeholder="2028"><label><input type="checkbox" name="active" checked> ativo</label><button class="btn small">Adicionar ano</button></form>
  <div class="cards"><% yrs.forEach(y=>{ %><div class="card"><h3><%= y.year %></h3><p><%= y.active?'Ativo':'Inativo' %></p><form method="post" action="/admin/year/<%= y.id %>/toggle"><button class="btn small">Ativar/desativar</button></form></div><% }) %></div>
  <h2>Menu dos pacotes</h2>
  <div class="package-tabs"><% [...new Set(packs.map(p=>p.name))].forEach(n=>{ %><a href="#pkg-<%= n.replace(/[^a-zA-Z0-9]/g,'-') %>"><%= n %></a><% }) %></div>
  <h2>Adicionar pacote</h2>
  <form class="form-grid cat-form" method="post" action="/admin/package">
    <select name="year_id"><% yrs.forEach(y=>{ %><option value="<%= y.id %>"><%= y.year %></option><% }) %></select><input name="name" placeholder="Nome do pacote"><input name="subtitle" placeholder="Ex: 50 pessoas"><input name="base_people" type="number" placeholder="Pessoas base"><input name="duration" placeholder="Duração"><input name="availability" placeholder="Dias disponíveis"><textarea name="included" placeholder="Resumo principal sem preço"></textarea><textarea name="rules" placeholder="Regras"></textarea><input type="hidden" name="categories_json" class="categories-json">
    <div class="cat-editor"><% catNames.forEach(c=>{ %><label><span><%= c %></span><textarea class="cat-textarea" data-cat="<%= c %>" placeholder="Um item por linha"></textarea></label><% }) %></div>
    <label><input type="checkbox" name="active" checked> Ativo</label><label><input type="checkbox" name="featured"> Destaque</label><button class="btn">Salvar pacote</button>
  </form>
  <h2>Pacotes cadastrados</h2><div class="package-admin-list"><% packs.forEach(p=>{ const cats=p.categories||{}; %><details class="card" id="pkg-<%= p.name.replace(/[^a-zA-Z0-9]/g,'-') %>"><summary><b><%= p.year %> — <%= p.name %></b> • <%= p.active?'Ativo':'Inativo' %></summary><form class="form-grid cat-form" method="post" action="/admin/package"><input type="hidden" name="id" value="<%= p.id %>"><select name="year_id"><% yrs.forEach(y=>{ %><option value="<%= y.id %>" <%= y.id===p.year_id?'selected':'' %>><%= y.year %></option><% }) %></select><input name="name" value="<%= p.name %>"><input name="subtitle" value="<%= p.subtitle %>"><input name="base_people" type="number" value="<%= p.base_people %>"><input name="duration" value="<%= p.duration %>"><input name="availability" value="<%= p.availability %>"><textarea name="included"><%= p.included %></textarea><textarea name="rules"><%= p.rules %></textarea><input type="hidden" name="categories_json" class="categories-json"><div class="cat-editor"><% catNames.forEach(c=>{ %><label><span><%= c %></span><textarea class="cat-textarea" data-cat="<%= c %>"><%= Array.isArray(cats[c]) ? cats[c].join('\n') : '' %></textarea></label><% }) %></div><label><input type="checkbox" name="active" <%= p.active?'checked':'' %>> Ativo</label><label><input type="checkbox" name="featured" <%= p.featured?'checked':'' %>> Destaque</label><button class="btn">Salvar alterações</button></form><form method="post" action="/admin/package/<%= p.id %>/delete" onsubmit="return confirm('Excluir este pacote?')"><button>Excluir pacote</button></form></details><% }) %></div>
  <script>document.querySelectorAll('.cat-form').forEach(f=>f.addEventListener('submit',()=>{const obj={};f.querySelectorAll('.cat-textarea').forEach(t=>{const arr=t.value.split('\n').map(x=>x.trim()).filter(Boolean); if(arr.length)obj[t.dataset.cat]=arr;});f.querySelector('.categories-json').value=JSON.stringify(obj);}));</script>
<% } %>

<% if(page==='site'){ %>
  <h1>Site, banners e promoções</h1><h2>Informações gerais</h2><form class="form-grid" method="post" enctype="multipart/form-data" action="/admin/settings"><input name="site_title" value="<%= s.site_title %>"><input name="whatsapp" value="<%= s.whatsapp %>"><input name="instagram" value="<%= s.instagram %>"><input name="address" value="<%= s.address %>"><input name="hero_title" value="<%= s.hero_title %>"><textarea name="hero_subtitle"><%= s.hero_subtitle %></textarea><input name="footer_text" value="<%= s.footer_text %>"><label>Logo PNG<input type="file" name="logo" accept="image/png,image/svg+xml,image/webp"></label><label>Ícone da aba/favicon<input type="file" name="favicon" accept="image/png,image/svg+xml,image/webp"></label><button class="btn">Salvar</button></form>
  <h2>Novo banner</h2><form class="form-grid" method="post" enctype="multipart/form-data" action="/admin/banner"><input name="title" placeholder="Título"><input name="subtitle" placeholder="Subtítulo"><input name="button_text" placeholder="Texto do botão"><input name="button_link" placeholder="Link"><input type="file" name="image"><input name="sort_order" placeholder="Ordem"><label><input type="checkbox" name="active" checked> Ativo</label><button class="btn">Adicionar banner</button></form>
  <h2>Nova promoção</h2><form class="form-grid" method="post" enctype="multipart/form-data" action="/admin/promotion"><input name="title" placeholder="Título"><textarea name="description" placeholder="Descrição"></textarea><input name="button_text" placeholder="Texto do botão"><input name="link" placeholder="Link da promoção"><input type="file" name="image"><input type="date" name="starts_at"><input type="date" name="ends_at"><label><input type="checkbox" name="active" checked> Ativa</label><label><input type="checkbox" name="highlight" checked> Destaque na home</label><button class="btn">Adicionar promoção</button></form>
  <h2 id="depoimentos-admin">Depoimentos</h2><form class="form-grid" method="post" action="/admin/testimonial"><input name="name" placeholder="Nome da cliente"><textarea name="text" placeholder="Depoimento"></textarea><label><input type="checkbox" name="active" checked> Ativo</label><button class="btn">Adicionar depoimento</button></form><div class="cards"><% testimonials.forEach(t=>{ %><div class="card"><h3><%= t.name %></h3><p><%= t.text %></p><form method="post" action="/admin/testimonial/<%= t.id %>/delete"><button>Excluir</button></form></div><% }) %></div>
<% } %>

<% if(page==='leads'){ %>
  <h1>Leads / Solicitações</h1><div class="table"><table><tr><th>Cliente</th><th>WhatsApp</th><th>Festa</th><th>Pacote</th><th>Status</th></tr><% leads.forEach(l=>{ %><tr><td><%= l.name %></td><td><a href="https://wa.me/55<%= String(l.whatsapp).replace(/\D/g,'') %>"><%= l.whatsapp %></a></td><td><%= l.birthday_name %> • total: <%= l.guests %> • adultos: <%= l.adults||0 %> • 0-5: <%= l.kids_0_5||0 %> • 6-10: <%= l.kids_6_10||0 %> • <%= l.event_date %></td><td><%= l.package_name %> <%= l.year %></td><td><form method="post" action="/admin/leads/<%= l.id %>/status"><select name="status"><option><%= l.status %></option><option>novo</option><option>em atendimento</option><option>fechado</option><option>perdido</option></select><input name="notes" value="<%= l.notes||'' %>" placeholder="Observações"><button>Salvar</button></form></td></tr><% }) %></table></div>
<% } %>
</main></div></body></html>
