<%- include('partials/head') %><div class="admin-wrap"><aside><h2>Biruta Admin</h2><a href="/admin">Dashboard</a><a href="/admin/orcamentos">Orçamentos</a><a href="/admin/site">Site e promoções</a><a href="/admin/leads">Leads</a><a href="/admin/senha">Trocar senha</a><a href="/admin/logout">Sair</a></aside><main class="admin-main">
<% if(page==='dashboard'){ %><h1>Dashboard</h1><div class="cards"><div class="card"><h3>Últimas solicitações</h3><% leads.forEach(l=>{ %><p><b><%= l.name %></b> — <%= l.package_name %> — <%= l.guests %> convidados</p><% }) %></div></div><% } %>
<% if(page==='senha'){ %><h1>Trocar senha do painel</h1><div class="card"><% if(error){ %><p class="error"><%= error %></p><% } %><% if(ok){ %><p class="ok"><%= ok %></p><% } %><form class="form-grid" method="post" action="/admin/senha"><input name="current_password" type="password" placeholder="Senha atual"><input name="new_password" type="password" placeholder="Nova senha"><input name="confirm_password" type="password" placeholder="Confirmar nova senha"><button class="btn">Salvar nova senha</button></form></div><% } %>
<% if(page==='orcamentos'){ %><h1>Orçamentos por ano</h1><form class="inline" method="post" action="/admin/year"><input name="year" placeholder="2028"><label><input type="checkbox" name="active" checked> ativo</label><button class="btn small">Adicionar ano</button></form><div class="cards"><% yrs.forEach(y=>{ %><div class="card"><h3><%= y.year %></h3><p><%= y.active?'Ativo':'Inativo' %></p><form method="post" action="/admin/year/<%= y.id %>/toggle"><button class="btn small">Ativar/desativar</button></form></div><% }) %></div><h2>Adicionar/editar pacote</h2><form class="form-grid" method="post" action="/admin/package"><select name="year_id"><% yrs.forEach(y=>{ %><option value="<%= y.id %>"><%= y.year %></option><% }) %></select><input name="name" placeholder="Nome do pacote"><input name="subtitle" placeholder="Ex: 50 pessoas"><input name="base_people" type="number" placeholder="Pessoas base"><input name="base_price" type="number" step="0.01" placeholder="Valor base (somente admin)"><input name="card_price" type="number" step="0.01" placeholder="Valor cartão (opcional)"><input name="additional_price" type="number" step="0.01" placeholder="Valor adicional (somente admin)"><input name="duration" placeholder="Duração"><input name="availability" placeholder="Dias disponíveis"><textarea name="included" placeholder="Resumo principal sem preço"></textarea><textarea name="menu_details" placeholder="Cardápio completo e inclusos do pacote"></textarea><textarea name="rules" placeholder="Regras"></textarea><label><input type="checkbox" name="active" checked> Ativo</label><label><input type="checkbox" name="featured"> Destaque</label><button class="btn">Salvar pacote</button></form><h2>Pacotes cadastrados</h2><div class="package-admin-list"><% packs.forEach(p=>{ %><details class="card"><summary><b><%= p.year %> — <%= p.name %></b> • <%= money(p.base_price) %> • <%= p.active?'Ativo':'Inativo' %></summary><form class="form-grid" method="post" action="/admin/package"><input type="hidden" name="id" value="<%= p.id %>"><select name="year_id"><% yrs.forEach(y=>{ %><option value="<%= y.id %>" <%= y.id===p.year_id?'selected':'' %>><%= y.year %></option><% }) %></select><input name="name" value="<%= p.name %>"><input name="subtitle" value="<%= p.subtitle %>"><input name="base_people" type="number" value="<%= p.base_people %>"><input name="base_price" type="number" step="0.01" value="<%= p.base_price %>"><input name="card_price" type="number" step="0.01" value="<%= p.card_price||'' %>"><input name="additional_price" type="number" step="0.01" value="<%= p.additional_price %>"><input name="duration" value="<%= p.duration %>"><input name="availability" value="<%= p.availability %>"><textarea name="included"><%= p.included %></textarea><textarea name="menu_details"><%= p.menu_details||'' %></textarea><textarea name="rules"><%= p.rules %></textarea><label><input type="checkbox" name="active" <%= p.active?'checked':'' %>> Ativo</label><label><input type="checkbox" name="featured" <%= p.featured?'checked':'' %>> Destaque</label><button class="btn">Salvar alterações</button></form><form method="post" action="/admin/package/<%= p.id %>/delete" onsubmit="return confirm('Excluir este pacote?')"><button>Excluir pacote</button></form></details><% }) %></div><% } %>
<% if(page==='site'){ %><h1>Site, banners e promoções</h1><h2>Informações gerais</h2><form class="form-grid" method="post" action="/admin/settings"><input name="site_title" value="<%= s.site_title %>"><input name="whatsapp" value="<%= s.whatsapp %>"><input name="instagram" value="<%= s.instagram %>"><input name="address" value="<%= s.address %>"><input name="hero_title" value="<%= s.hero_title %>"><textarea name="hero_subtitle"><%= s.hero_subtitle %></textarea><input name="footer_text" value="<%= s.footer_text %>"><button class="btn">Salvar</button></form><h2>Novo banner</h2><form class="form-grid" method="post" enctype="multipart/form-data" action="/admin/banner"><input name="title" placeholder="Título"><input name="subtitle" placeholder="Subtítulo"><input name="button_text" placeholder="Texto do botão"><input name="button_link" placeholder="Link"><input type="file" name="image"><input name="sort_order" placeholder="Ordem"><label><input type="checkbox" name="active" checked> Ativo</label><button class="btn">Adicionar banner</button></form><h2>Nova promoção</h2><form class="form-grid" method="post" enctype="multipart/form-data" action="/admin/promotion"><input name="title" placeholder="Título"><textarea name="description" placeholder="Descrição"></textarea><input name="button_text" placeholder="Texto do botão"><input name="link" placeholder="Link da promoção"><input type="file" name="image"><input type="date" name="starts_at"><input type="date" name="ends_at"><label><input type="checkbox" name="active" checked> Ativa</label><label><input type="checkbox" name="highlight" checked> Destaque na home</label><button class="btn">Adicionar promoção</button></form><% } %>
<% if(page==='leads'){ %><h1>Leads / Solicitações</h1><div class="table"><table><tr><th>Cliente</th><th>WhatsApp</th><th>Festa</th><th>Pacote</th><th>Status</th></tr><% leads.forEach(l=>{ %><tr><td><%= l.name %></td><td><a href="https://wa.me/55<%= String(l.whatsapp).replace(/\D/g,'') %>"><%= l.whatsapp %></a></td><td><%= l.birthday_name %> • <%= l.guests %> convidados • <%= l.event_date %></td><td><%= l.package_name %> <%= l.year %></td><td><form method="post" action="/admin/leads/<%= l.id %>/status"><select name="status"><option><%= l.status %></option><option>novo</option><option>em atendimento</option><option>fechado</option><option>perdido</option></select><input name="notes" value="<%= l.notes||'' %>" placeholder="Observações"><button>Salvar</button></form></td></tr><% }) %></table></div><% } %>
</main></div></body></html>
