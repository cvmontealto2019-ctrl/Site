<%- include('partials/head') %>
<div class="admin-wrap"><aside><h2>Biruta Admin</h2><a href="/admin">Dashboard</a><a href="/admin/pacotes">Pacotes</a><a href="/admin/site">Site, banners e promoções</a><a href="/admin/leads">Solicitações</a><a href="/admin/senha">Login e senha</a><a href="/admin/logout">Sair</a></aside><main class="admin-main">
<% if(page==='dashboard'){ %>
  <h1>Dashboard</h1><div class="cards"><div class="card"><h3>Últimas solicitações</h3><% leads.forEach(l=>{ %><p><b><%= l.name %></b> — <%= l.package_name %> — <%= l.guests %> convidados</p><% }) %></div><div class="card"><h3>Atalhos</h3><p>Cadastre banners no tamanho recomendado: <b>1920 × 760 px</b> para desktop. Para melhor leitura no celular, mantenha textos centralizados e use imagem segura também em <b>1080 × 1350 px</b>.</p><a class="btn small" href="/admin/site">Editar site</a></div></div>
<% } %>

<% if(page==='senha'){ %>
  <h1>Trocar login e senha</h1><div class="card"><% if(error){ %><p class="error"><%= error %></p><% } %><% if(ok){ %><p class="ok"><%= ok %></p><% } %><form class="form-grid" method="post" action="/admin/senha"><input name="new_login" placeholder="Novo login" value="<%= (current_user && current_user.login) || '17717592000160' %>"><input name="current_password" type="password" placeholder="Senha atual"><input name="new_password" type="password" placeholder="Nova senha"><input name="confirm_password" type="password" placeholder="Confirmar nova senha"><button class="btn">Salvar</button></form></div>
<% } %>

<% if(page==='pacotes'){ %>
  <h1>Pacotes atuais</h1><p class="admin-note">Agora existe apenas uma lista principal de pacotes. O que você alterar aqui aparece no site e no orçamento online.</p>
  <div class="package-tabs"><% packs.forEach(p=>{ %><a href="#pkg-<%= p.id %>"><%= p.name %></a><% }) %><a href="#novo-pacote">+ Novo pacote</a></div>
  <section id="novo-pacote" class="card"><h2>Adicionar pacote</h2><%- include('partials/package-form', {p:null, categoriesOrder}) %></section>
  <h2>Editar pacotes</h2><div class="package-admin-list"><% packs.forEach(p=>{ %><details class="card" id="pkg-<%= p.id %>"><summary><b><%= p.name %></b> • <%= p.active?'Ativo':'Inativo' %></summary><%- include('partials/package-form', {p, categoriesOrder}) %><form method="post" action="/admin/package/<%= p.id %>/delete" onsubmit="return confirm('Excluir este pacote?')"><button class="danger">Excluir pacote</button></form></details><% }) %></div>
  <script>document.querySelectorAll('.cat-form').forEach(f=>f.addEventListener('submit',()=>{const obj={};f.querySelectorAll('.cat-textarea').forEach(t=>{const arr=t.value.split('\n').map(x=>x.trim()).filter(Boolean); if(arr.length)obj[t.dataset.cat]=arr;});f.querySelector('.categories-json').value=JSON.stringify(obj);}));</script>
<% } %>

<% if(page==='site'){ %>
  <h1>Site, banners e promoções</h1>
  <section class="card"><h2>Informações gerais</h2><form class="form-grid" method="post" enctype="multipart/form-data" action="/admin/settings"><input name="site_title" value="<%= s.site_title %>" placeholder="Título do site"><input name="whatsapp" value="<%= s.whatsapp %>" placeholder="WhatsApp com DDI"><input name="instagram" value="<%= s.instagram %>" placeholder="Instagram"><input name="address" value="<%= s.address %>" placeholder="Endereço"><input name="hero_title" value="<%= s.hero_title %>" placeholder="Título principal"><textarea name="hero_subtitle"><%= s.hero_subtitle %></textarea><input name="footer_text" value="<%= s.footer_text %>" placeholder="Texto do rodapé"><label>Enviar logo em PNG/SVG/WebP<input type="file" name="logo" accept="image/png,image/svg+xml,image/webp"></label><label>Ícone da aba/favicon<input type="file" name="favicon" accept="image/png,image/svg+xml,image/webp"></label><button class="btn">Salvar informações</button></form></section>
  <section class="card" id="banners-admin"><h2>Carrossel de banners</h2><p class="admin-note">Tamanho recomendado: <b>1920 × 760 px</b>. Para artes usadas também em stories/feed, mantenha uma versão <b>1080 × 1350 px</b>.</p><form class="form-grid" method="post" enctype="multipart/form-data" action="/admin/banner"><input name="title" placeholder="Título"><input name="subtitle" placeholder="Subtítulo"><input name="button_text" placeholder="Texto do botão"><input name="button_link" placeholder="Link exato: https://... ou mesdasmaes.birutapark.com.br"><input type="file" name="image"><input name="sort_order" type="number" placeholder="Ordem"><label><input type="checkbox" name="active" checked> Ativo</label><button class="btn">Adicionar banner</button></form><div class="cards"><% banners.forEach(b=>{ %><div class="card mini"><% if(b.image_url){ %><img class="thumb" src="<%= b.image_url %>"><% } %><h3><%= b.title %></h3><p><%= b.subtitle %></p><p><small><%= b.button_link %></small></p><form method="post" action="/admin/banner/<%= b.id %>/delete"><button class="danger">Excluir</button></form></div><% }) %></div></section>
  <section class="card" id="promocoes-admin"><h2>Promoções</h2><form class="form-grid" method="post" enctype="multipart/form-data" action="/admin/promotion"><input name="title" placeholder="Título"><textarea name="description" placeholder="Descrição curta"></textarea><input name="button_text" placeholder="Texto do botão"><input name="link" placeholder="Link exato da promoção"><input type="file" name="image"><input type="date" name="starts_at"><input type="date" name="ends_at"><label><input type="checkbox" name="active" checked> Ativa</label><label><input type="checkbox" name="highlight" checked> Destaque na home</label><button class="btn">Adicionar promoção</button></form><div class="cards"><% promos.forEach(p=>{ %><div class="card mini"><% if(p.image_url){ %><img class="thumb" src="<%= p.image_url %>"><% } %><h3><%= p.title %></h3><p><%= p.description %></p><p><small><%= p.link %></small></p><form method="post" action="/admin/promotion/<%= p.id %>/delete"><button class="danger">Excluir</button></form></div><% }) %></div></section>
  <section class="card" id="depoimentos-admin"><h2>Depoimentos</h2><form class="form-grid" method="post" action="/admin/testimonial"><input name="name" placeholder="Nome da cliente"><textarea name="text" placeholder="Depoimento"></textarea><label><input type="checkbox" name="active" checked> Ativo</label><button class="btn">Adicionar depoimento</button></form><div class="cards"><% testimonials.forEach(t=>{ %><div class="card mini"><h3><%= t.name %></h3><p><%= t.text %></p><form method="post" action="/admin/testimonial/<%= t.id %>/delete"><button class="danger">Excluir</button></form></div><% }) %></div></section>
<% } %>

<% if(page==='leads'){ %>
  <h1>Solicitações de orçamento</h1><div class="table"><table><tr><th>Cliente</th><th>WhatsApp</th><th>Festa</th><th>Pacote</th><th>Status</th></tr><% leads.forEach(l=>{ %><tr><td><b><%= l.name %></b></td><td><a href="https://wa.me/55<%= String(l.whatsapp).replace(/\D/g,'') %>"><%= l.whatsapp %></a></td><td><%= l.birthday_name %> • <%= l.event_date %><br>Total: <%= l.guests %> | Adultos: <%= l.adults||0 %> | 0-5: <%= l.kids_0_5||0 %> | 6-10: <%= l.kids_6_10||0 %></td><td><%= l.package_name %></td><td><form method="post" action="/admin/leads/<%= l.id %>/status"><select name="status"><option><%= l.status %></option><option>novo</option><option>em atendimento</option><option>fechado</option><option>perdido</option></select><input name="notes" value="<%= l.notes||'' %>" placeholder="Observações"><button>Salvar</button></form></td></tr><% }) %></table></div>
<% } %>
</main></div></body></html>
