<%- include('partials/head') %><%- include('partials/header') %>
<main class="home">
<section class="hero">
  <div class="float-logos"><img src="<%= s.logo_url||'/public/assets/logo.svg' %>"><img src="<%= s.logo_url||'/public/assets/logo.svg' %>"><img src="<%= s.logo_url||'/public/assets/logo.svg' %>"><img src="<%= s.logo_url||'/public/assets/logo.svg' %>"></div>
  <div class="hero-card">
    <span class="pill">Deixe a diversão te guiar!</span>
    <h1><%= s.hero_title %></h1>
    <p><%= s.hero_subtitle %></p>
    <div class="actions"><a class="btn" href="/orcamento">Pedir meu orçamento</a><a class="btn ghost" href="#pacotes">Ver pacotes</a></div>
  </div>
  <div class="promo-card"><span class="pill orange">Promoção em destaque</span><% if(promo){ %><% if(promo.image_url){ %><img class="thumb" src="<%= promo.image_url %>" alt="<%= promo.title %>"><% } %><h3><%= promo.title %></h3><p><%= promo.description %></p><a class="btn small" href="<%= promo.link %>"><%= promo.button_text %></a><% } else { %><h3>Nenhuma promoção ativa.</h3><p>As próximas campanhas aparecerão aqui.</p><% } %></div>
</section>
<section class="section" id="estrutura"><div class="section-head"><span class="pill">Nossa estrutura</span><h2>Um buffet completo para todas as idades</h2><p>Ambiente climatizado, recepção moderna, som, iluminação, máquina de fumaça, máquina de bolhas e atrações para transformar a festa em uma experiência inesquecível.</p></div><div class="grid"><div class="feature">1.100m² de diversão</div><div class="feature">Até 150 convidados</div><div class="feature">Brinquedos e games</div><div class="feature">Equipe completa</div></div></section>
<section class="section" id="pacotes"><div class="section-head"><span class="pill">Pacotes</span><h2>Conheça nossas opções</h2><p>Veja as principais informações. Para valores e disponibilidade, faça a solicitação pelo orçamento online.</p></div><div class="cards"><% packs.forEach(p=>{ const cats=p.categories||{}; %><article class="card package-card"><span class="badge"><%= p.duration %></span><h3><%= p.name %></h3><p><b><%= p.subtitle %></b> • <%= p.availability %></p><p><%= p.included %></p><details><summary>Ver cardápio e inclusos</summary><div class="menu-details"><% Object.entries(cats).forEach(([k,items])=>{ %><div class="cat"><h4><%= k %></h4><ul><% (items||[]).forEach(i=>{ %><li><%= i %></li><% }) %></ul></div><% }) %></div></details><a href="/orcamento" class="btn small">Solicitar orçamento</a></article><% }) %></div></section>
<section class="section promo-strip"><h2>Quer uma proposta personalizada?</h2><p>Responda algumas perguntas rápidas e envie sua solicitação direto para nossa equipe.</p><a href="/orcamento" class="btn">Começar agora</a></section>
<section class="section" id="depoimentos"><div class="section-head"><span class="pill">Depoimentos</span><h2>Quem festeja aqui, recomenda</h2></div><div class="cards"><% if(deps.length){ deps.forEach(d=>{ %><article class="card"><h3><%= d.name %></h3><p><%= d.text||d.message %></p></article><% }) } else { %><article class="card"><p>Cadastre depoimentos no painel admin.</p></article><% } %></div></section>
</main><%- include('partials/footer') %>
