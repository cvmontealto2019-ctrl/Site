<%- include('partials/head') %><%- include('partials/header') %>
<main class="home">
  <section class="hero">
    <div class="float-logos">
      <% for(let i=0;i<10;i++){ %><img src="<%= s.logo_url||'/public/assets/logo.svg' %>" alt=""><% } %>
    </div>
    <div class="banner-carousel" data-carousel>
      <% if(banners.length){ banners.forEach((b,i)=>{ %>
        <article class="banner-slide <%= i===0?'active':'' %>" style="background-image:linear-gradient(90deg,rgba(6,54,102,.82),rgba(255,106,0,.35)),url('<%= b.image_url %>')">
          <div class="banner-content">
            <span class="pill">Buffet Biruta Park</span>
            <h1><%= b.title %></h1>
            <% if(b.subtitle){ %><p><%= b.subtitle %></p><% } %>
            <% if(b.button_text){ %><a class="btn" href="<%= promoLink(b.button_link) %>"><%= b.button_text %></a><% } %>
          </div>
        </article>
      <% }) } else { %>
        <article class="banner-slide active default-hero"><div class="banner-content"><span class="pill">Deixe a diversão te guiar!</span><h1><%= s.hero_title %></h1><p><%= s.hero_subtitle %></p><a class="btn" href="/orcamento">Pedir orçamento</a></div></article>
      <% } %>
      <div class="carousel-dots"><% (banners.length?banners:[1]).forEach((_,i)=>{ %><button data-dot="<%= i %>" class="<%= i===0?'active':'' %>"></button><% }) %></div>
    </div>
  </section>

  <% if(promo){ %>
  <section class="promo-highlight">
    <div><span class="pill orange">Promoção em destaque</span><h2><%= promo.title %></h2><p><%= promo.description %></p></div>
    <% if(promo.image_url){ %><img src="<%= promo.image_url %>" alt="<%= promo.title %>"><% } %>
    <a class="btn" href="<%= promoLink(promo.link) %>"><%= promo.button_text||'Participar' %></a>
  </section>
  <% } %>

  <section class="section" id="estrutura">
    <div class="section-head"><span class="pill">Nossa estrutura</span><h2>Um espaço completo para comemorar com conforto</h2></div>
    <div class="grid features-grid"><div class="feature">Ambiente climatizado</div><div class="feature">1.100m² de diversão</div><div class="feature">Até 150 convidados</div><div class="feature">Som, luz, fumaça e bolhas</div><div class="feature">Recepção moderna</div><div class="feature">Brinquedos e games</div></div>
  </section>

  <section class="section" id="pacotes">
    <div class="section-head"><span class="pill">Pacotes</span><h2>Conheça nossas opções</h2><p>Escolha um pacote para visualizar os inclusos. Para valores e disponibilidade, envie a solicitação pelo orçamento online.</p></div>
    <div class="cards packages-grid">
      <% packs.forEach(p=>{ %>
      <article class="card package-card">
        <span class="badge"><%= p.duration %></span><h3><%= p.name %></h3><p class="package-sub"><%= p.subtitle %> • <%= p.availability %></p><p><%= p.summary %></p>
        <details><summary>Ver cardápio e inclusos</summary><div class="menu-details"><% categoriesOrder.forEach(cat=>{ const items=(p.categories||{})[cat]||[]; if(items.length){ %><div class="cat"><h4><%= cat %></h4><ul><% items.forEach(i=>{ %><li><%= i %></li><% }) %></ul></div><% } }) %></div></details>
        <a href="/orcamento" class="btn small">Solicitar orçamento</a>
      </article>
      <% }) %>
    </div>
  </section>

  <section class="section cta-section"><h2>Quer uma proposta personalizada?</h2><p>Preencha as informações da festa e fale direto com a nossa equipe pelo WhatsApp.</p><a href="/orcamento" class="btn">Começar agora</a></section>

  <section class="section" id="depoimentos"><div class="section-head"><span class="pill">Depoimentos</span><h2>Quem festeja aqui, recomenda</h2></div><div class="cards"><% if(deps.length){ deps.forEach(d=>{ %><article class="card"><h3><%= d.name %></h3><p><%= d.text %></p></article><% }) } else { %><article class="card"><p>Os depoimentos cadastrados no painel aparecerão aqui.</p></article><% } %></div></section>
</main><%- include('partials/footer') %>
