<%- include('partials/head') %><%- include('partials/header') %>
<main class="home">
<section class="hero"><div class="float-logos"><img src="/public/assets/logo.svg"><img src="/public/assets/logo.svg"><img src="/public/assets/logo.svg"></div><div class="hero-card"><span class="pill">Deixe a diversão te guiar!</span><h1><%= s.hero_title %></h1><p><%= s.hero_subtitle %></p><div class="actions"><a class="btn" href="/orcamento">Montar meu orçamento</a><a class="btn ghost" href="#estrutura">Conhecer estrutura</a></div></div><div class="promo-card"><h3>Promoção em destaque</h3><% if(promo){ %><p><%= promo.title %></p><small><%= promo.description %></small><a class="btn small" href="<%= promo.link %>"><%= promo.button_text %></a><% } else { %><p>Nenhuma promoção ativa.</p><% } %></div></section>
<section class="section" id="estrutura"><h2>Nossa estrutura</h2><p>Ambiente climatizado, recepção moderna, som, iluminação, máquina de fumaça, máquina de bolhas e 21 atrações para todas as idades.</p><div class="grid"><div class="feature">1.100m² de diversão</div><div class="feature">Até 150 convidados</div><div class="feature">Brinquedos e games</div><div class="feature">Equipe completa</div></div></section>
<section class="section" id="pacotes"><h2>Pacotes</h2><div class="cards"><% packs.forEach(p=>{ %><article class="card"><span><%= p.year %></span><h3><%= p.name %></h3><p><%= p.duration %> • <%= p.subtitle %></p><strong><%= money(p.base_price) %></strong><a href="/orcamento" class="btn small">Simular</a></article><% }) %></div></section>
<section class="section"><h2>Depoimentos</h2><div class="cards"><% if(deps.length){ deps.forEach(d=>{ %><article class="card"><h3><%= d.name %></h3><p><%= d.message %></p></article><% }) } else { %><article class="card"><p>Cadastre depoimentos no painel admin.</p></article><% } %></div></section>
</main><%- include('partials/footer') %>
