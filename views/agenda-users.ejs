<%- include('partials/head') %>
<main class="agenda-shell">
  <header class="agenda-top">
    <div><img src="<%= s.logo_url || '/public/assets/logo.svg' %>" alt="Biruta"><h1>Usuários da Agenda</h1><p>Controle separado do painel do site</p></div>
    <nav><a href="/agendadecoracao">Início</a><a href="/agendadecoracao/calendario">Calendário</a><a href="/agendadecoracao/relatorio">Relatório</a><a href="/agendadecoracao/logout">Sair</a></nav>
  </header>
  <section class="card"><h2>Criar novo usuário</h2><form class="form-grid" method="post" action="/agendadecoracao/usuarios"><input name="name" placeholder="Nome"><input name="login" placeholder="Login"><input name="password" placeholder="Senha"><select name="role"><option value="admin">Administrador da agenda</option><option value="equipe">Equipe - cadastra e edita</option><option value="visualizacao">Visualização</option></select><button class="btn">Adicionar usuário</button></form></section>
  <section class="card"><h2>Usuários cadastrados</h2><div class="table"><table><thead><tr><th>Nome</th><th>Login</th><th>Nível</th><th>Editar</th></tr></thead><tbody><% users.forEach(u=>{ %><tr><td><%= u.name %></td><td><%= u.login %></td><td><%= u.role %></td><td><form class="inline-edit" method="post" action="/agendadecoracao/usuarios"><input type="hidden" name="id" value="<%= u.id %>"><input name="name" value="<%= u.name %>"><input name="login" value="<%= u.login %>"><input name="password" placeholder="Nova senha opcional"><select name="role"><option value="admin" <%= u.role==='admin'?'selected':'' %>>Administrador</option><option value="equipe" <%= u.role==='equipe'?'selected':'' %>>Equipe</option><option value="visualizacao" <%= u.role==='visualizacao'?'selected':'' %>>Visualização</option></select><button class="btn tiny">Salvar</button></form><form method="post" action="/agendadecoracao/usuarios/<%= u.id %>/delete" onsubmit="return confirm('Excluir usuário?')"><button class="danger">Excluir</button></form></td></tr><% }) %></tbody></table></div></section>
</main></body></html>
